# Copy this file to .env and fill in your values
# cp .env.example .env

# SQL Server Configuration
DB_SERVER=localhost
DB_NAME=SupportOpsDB
DB_USER=sa
DB_PASSWORD=YourStrong!Password123

# API Configuration
APP_ENV=development
APP_PORT=8000

# Automation intervals (in seconds)
MONITOR_INTERVAL=60
ESCALATION_INTERVAL=120

# Health check targets (comma-separated URLs to monitor)
MONITOR_URLS=http://api:8000/health,https://httpbin.org/status/200

# Thresholds
DISK_THRESHOLD_PERCENT=85
CPU_THRESHOLD_PERCENT=90
RAM_THRESHOLD_PERCENT=90

# Grafana
GRAFANA_PASSWORD=admin

# Slack Webhooks (optional)
# Create a webhook at https://api.slack.com/apps → Incoming Webhooks
# If left empty, Slack notifications are silently skipped.
# Alerts are sent for: critical/high auto-tickets, SLA breaches, and escalations.
SLACK_WEBHOOK_URL=
