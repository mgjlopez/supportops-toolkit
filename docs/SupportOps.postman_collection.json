        {
          "name": "Update ticket \u2014 assign and change status",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/tickets/{{ticket_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\",\n  \"assignee\": \"sysadmin1\"\n}"
            },
            "description": "Partial update \u2014 assigns the ticket and changes status to in_progress."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
