            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('API is ok', () => pm.expect(pm.response.json().api).to.eql('ok'));",
                  "pm.test('DB is ok',  () => pm.expect(pm.response.json().database).to.eql('ok'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Health check \u2014 response body validation",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Validates the response body schema (api/database fields) and response time.",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('API status is ok', () => pm.expect(pm.response.json().api).to.eql('ok'));",
                  "pm.test('Database field is present', () => pm.expect(pm.response.json()).to.have.property('database'));",
                  "pm.test('Response time under 500ms', () => pm.expect(pm.response.responseTime).to.be.below(500));"
                ]
              }
            }
          ]
        },
        {
          "name": "Health check \u2014 response time SLA",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Enforces a response-time SLA of under 200ms.",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response time is under 200ms', () => pm.expect(pm.response.responseTime).to.be.below(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Prometheus Metrics",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/metrics",
            "description": "Returns raw Prometheus metrics scraped by Grafana.",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contains supportops metrics', () => pm.expect(pm.response.text()).to.include('supportops_tickets_total'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "List all tickets",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tickets",
            "description": "Returns all tickets ordered by creation date.",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "List tickets \u2014 filter by status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tickets?status=open",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "open"
                }
              ]
            },
            "description": "Filter tickets by status. Valid values: open, in_progress, escalated, resolved, closed.",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All tickets are open', () => {",
                  "  pm.response.json().forEach(t => pm.expect(t.status).to.eql('open'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List tickets \u2014 filter by priority",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tickets?priority=critical",
